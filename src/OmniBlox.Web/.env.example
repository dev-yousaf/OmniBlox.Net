# Backend API URL — used in browser (client-side)
NEXT_PUBLIC_API_URL=https://YOUR_RENDER_API_URL

# Backend API URL — used during Server-Side Rendering (SSR)
API_URL=https://YOUR_RENDER_API_URL

# Local development overrides — create .env.local from this
# NEXT_PUBLIC_API_URL=http://localhost:5005
# API_URL=http://localhost:5005
