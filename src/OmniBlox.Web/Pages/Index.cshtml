@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Total Products</p>
        <p class="text-2xl font-bold text-gray-900 mt-1">@Model.Stats.TotalProducts</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Low Stock Items</p>
        <p class="text-2xl font-bold text-amber-600 mt-1">@Model.Stats.LowStockCount</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500">Total Inventory Value</p>
        <p class="text-2xl font-bold text-gray-900 mt-1">@Model.Stats.TotalValue.ToString("C")</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="font-semibold text-gray-900">Recent Products</h2>
        <a href="/products" class="text-sm text-blue-600 hover:underline">View all</a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="text-left text-sm text-gray-500 border-b border-gray-100">
                    <th class="px-6 py-3 font-medium">Name</th>
                    <th class="px-6 py-3 font-medium">SKU</th>
                    <th class="px-6 py-3 font-medium">Price</th>
                    <th class="px-6 py-3 font-medium">Stock</th>
                    <th class="px-6 py-3 font-medium">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.RecentProducts)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50">
                        <td class="px-6 py-3">
                            <a href="/products/edit/@product.Id" class="text-blue-600 hover:underline font-medium">@product.Name</a>
                        </td>
                        <td class="px-6 py-3 text-sm text-gray-600">@product.SKU</td>
                        <td class="px-6 py-3 text-sm">@product.SalePrice.ToString("C")</td>
                        <td class="px-6 py-3 text-sm">
                            <span class="@(product.StockQuantity <= product.ReorderLevel ? "text-red-600 font-medium" : "text-gray-600")">
                                @product.StockQuantity
                            </span>
                        </td>
                        <td class="px-6 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                @(product.Status == "ACTIVE" ? "bg-green-100 text-green-800" :
                                  product.Status == "INACTIVE" ? "bg-gray-100 text-gray-800" :
                                  "bg-red-100 text-red-800")">
                                @product.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
