@page
@model ProductsIndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="font-semibold text-gray-900">All Products</h2>
        <a href="/products/create" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium transition-colors">
            + New Product
        </a>
    </div>

    <form method="get" class="px-6 py-3 border-b border-gray-100 flex gap-3">
        <input type="text" name="search" value="@Model.Search" placeholder="Search by name or SKU..."
               class="flex-1 px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
        <button type="submit" class="px-4 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm font-medium">Search</button>
    </form>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="text-left text-sm text-gray-500 border-b border-gray-100">
                    <th class="px-6 py-3 font-medium">Name</th>
                    <th class="px-6 py-3 font-medium">SKU</th>
                    <th class="px-6 py-3 font-medium">Category</th>
                    <th class="px-6 py-3 font-medium">Price</th>
                    <th class="px-6 py-3 font-medium">Cost</th>
                    <th class="px-6 py-3 font-medium">Stock</th>
                    <th class="px-6 py-3 font-medium">Status</th>
                    <th class="px-6 py-3 font-medium"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50">
                        <td class="px-6 py-3">
                            <a href="/products/edit/@product.Id" class="text-blue-600 hover:underline font-medium">@product.Name</a>
                        </td>
                        <td class="px-6 py-3 text-sm text-gray-600">@product.SKU</td>
                        <td class="px-6 py-3 text-sm text-gray-600">@product.Category</td>
                        <td class="px-6 py-3 text-sm">@product.SalePrice.ToString("C")</td>
                        <td class="px-6 py-3 text-sm">@product.CostPrice.ToString("C")</td>
                        <td class="px-6 py-3 text-sm">
                            <span class="@(product.StockQuantity <= product.ReorderLevel ? "text-red-600 font-medium" : "text-gray-600")">
                                @product.StockQuantity
                            </span>
                        </td>
                        <td class="px-6 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                @(product.Status == "ACTIVE" ? "bg-green-100 text-green-800" :
                                  product.Status == "INACTIVE" ? "bg-gray-100 text-gray-800" :
                                  "bg-red-100 text-red-800")">
                                @product.Status
                            </span>
                        </td>
                        <td class="px-6 py-3">
                            <a href="/products/edit/@product.Id" class="text-blue-600 hover:text-blue-800 text-sm">Edit</a>
                        </td>
                    </tr>
                }
                @if (Model.Products.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-gray-500">
                            No products found.
                            <a href="/products/create" class="text-blue-600 hover:underline ml-1">Create one?</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between text-sm">
            <span class="text-gray-500">Page @Model.CurrentPage of @Model.TotalPages (@Model.Total products)</span>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?page=@(Model.CurrentPage - 1)&search=@Model.Search" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">Previous</a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="?page=@(Model.CurrentPage + 1)&search=@Model.Search" class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-50">Next</a>
                }
            </div>
        </div>
    }
</div>
