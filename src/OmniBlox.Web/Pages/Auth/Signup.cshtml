@page
@model SignupModel
@{
    ViewData["Title"] = "Sign up";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up - OmniBlox</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen flex items-center justify-center px-4 py-8">
        <div class="max-w-md w-full">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-blue-600">OmniBlox</h1>
                <p class="text-gray-600 mt-2">Create your company account</p>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post">
                    <div class="space-y-4">
                        <div>
                            <label for="Name" class="block text-sm font-medium text-gray-700 mb-1">Your Name *</label>
                            <input type="text" id="Name" name="Name" value="@Model.Name" required maxlength="200"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                        </div>
                        <div>
                            <label for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                            <input type="email" id="Email" name="Email" value="@Model.Email" required
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                        </div>
                        <div>
                            <label for="Password" class="block text-sm font-medium text-gray-700 mb-1">Password *</label>
                            <input type="password" id="Password" name="Password" required minlength="8"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                            <p class="text-xs text-gray-500 mt-1">At least 8 characters</p>
                        </div>
                        <div>
                            <label for="CompanyName" class="block text-sm font-medium text-gray-700 mb-1">Company Name *</label>
                            <input type="text" id="CompanyName" name="CompanyName" value="@Model.CompanyName" required maxlength="200"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                        </div>
                        <div>
                            <label for="WorkspaceUrl" class="block text-sm font-medium text-gray-700 mb-1">Workspace URL *</label>
                            <input type="text" id="WorkspaceUrl" name="WorkspaceUrl" value="@Model.WorkspaceUrl" required maxlength="200"
                                   pattern="^[a-z0-9-]+$"
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                            <p class="text-xs text-gray-500 mt-1">Lowercase letters, numbers, and dashes only</p>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label for="Industry" class="block text-sm font-medium text-gray-700 mb-1">Industry</label>
                                <input type="text" id="Industry" name="Industry" value="@Model.Industry" maxlength="100"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                            </div>
                            <div>
                                <label for="Country" class="block text-sm font-medium text-gray-700 mb-1">Country</label>
                                <input type="text" id="Country" name="Country" value="@Model.Country" maxlength="100"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
                            </div>
                        </div>
                        <button type="submit"
                                class="w-full py-2.5 px-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition-colors">
                            Create Account
                        </button>
                    </div>
                </form>

                <p class="text-center text-sm text-gray-600 mt-6">
                    Already have an account?
                    <a href="/auth/login" class="text-blue-600 hover:underline font-medium">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>
